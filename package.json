{
  "name": "qa-automation-playwright",
  "version": "1.0.0",
  "description": "QA Automation Assessment — Playwright + TypeScript (SauceDemo + API)",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test tests/ui/",
    "test:api": "playwright test tests/api/",
    "test:negative": "playwright test tests/negative/",
    "test:headed": "playwright test --headed",
    "test:report": "playwright show-report",
    "test:trace": "playwright test --trace on",
    "lint": "eslint . --ext .ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/node": "^20.12.0",
    "dotenv": "^16.4.5",
    "typescript": "^5.4.5"
  }
}
